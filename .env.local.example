# Copy to .env.local (gitignored) and fill in from your Supabase project
# settings once it exists. Never commit real values.

# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Project Settings -> API -> service_role secret.
# Server-only — never reference this from a Client Component or anything
# bundled to the browser. Used only by scripts/migrate-to-supabase.mts and
# admin Server Actions/Route Handlers, after an explicit role check.
SUPABASE_SERVICE_ROLE_KEY=

# Transactional email for RFQ notifications (Phase 3.11).
RESEND_API_KEY=
RFQ_NOTIFICATION_EMAIL=trade@leosdubai.com

NEXT_PUBLIC_SITE_URL=https://www.leosdubai.com
